# API Configuration for Coisas de Garagem Frontend

# Backend API URL
# For local development on desktop browser:
VITE_API_BASE_URL=http://localhost:3000/api/v1

# For Android emulator (use 10.0.2.2 instead of localhost):
# VITE_API_BASE_URL=http://10.0.2.2:3000/api/v1

# For Android device on the same network (replace with your computer's IP):
# VITE_API_BASE_URL=http://192.168.1.100:3000/api/v1

# For production backend:
# VITE_API_BASE_URL=https://api.coisasdegaragem.com/api/v1

# Enable mock data for testing without backend:
# VITE_ENABLE_MOCK_DATA=true
